{
  "name": "claude-neo4j-memory",
  "version": "0.2.0",
  "description": "Persistent, graph-based memory for Claude Code backed by Neo4j (local Docker or remote/Aura).",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bash tests/launcher-path.test.sh && node --test tests/**/*.test.js",
    "configure": "node scripts/configure.mjs",
    "mcp-server": "node src/mcp/server.js",
    "memory": "node scripts/memory-cli.mjs",
    "usage": "bash scripts/memory-usage.sh",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "token-cost": "node scripts/token-cost.mjs",
    "migrate-claude-mem": "node scripts/migrate-from-claude-mem.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "neo4j-driver": "^5.28.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
